# -----------------------------------------------------------------------------
# PZ-owned bytecode — NEVER commit. Populated by `./mod.ps1 init` from the
# user's local Steam install.
# -----------------------------------------------------------------------------
/classes-original/
/libs/

# -----------------------------------------------------------------------------
# Generated/decompiled sources — regenerated by `./mod.ps1 init`
# (src-pristine) and `./mod.ps1 enter|reset` (src).
# -----------------------------------------------------------------------------
/src/
/src-pristine/

# -----------------------------------------------------------------------------
# Downloaded tooling — `./mod.ps1 init` fetches vineflower.jar.
# Keep the tools/ directory itself tracked via .gitkeep if empty.
# -----------------------------------------------------------------------------
/tools/*
!/tools/.gitkeep

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
/build/

# -----------------------------------------------------------------------------
# Local runtime state — user-specific, not shared
# -----------------------------------------------------------------------------
/.mod-config.json
/.mod-state.json
/.mod-enter.json

# -----------------------------------------------------------------------------
# Editor / OS junk
# -----------------------------------------------------------------------------
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
Thumbs.db
Desktop.ini
*.swp
*~
