# -----------------------------------------------------------------------------
# Workspace state lives inside the PZ install at <pz>/necroid/, not here in
# the checkout. The checkout only carries the pointer file, an entered-mod
# record, downloaded tooling, and per-mod editable working trees.
# -----------------------------------------------------------------------------

# Per-mod editable working trees — `necroid enter <mod>` seeds one at
# `/src-<mod>/`. Ephemeral; user-local. `necroid clean` removes them.
/src-*/

# Downloaded tooling. The tools/ dir itself is tracked via .gitkeep; contents are not.
/data/tools/*

# Workspace anchor — points at the PZ install holding <pz>/necroid/
/data/.necroid-pointer.json
# Currently-entered mod (per-checkout work-in-progress)
/data/.mod-enter.json
# Self-update TTL for the binary
/data/.update-cache.json

# Legacy paths from pre-PZ-anchored Necroid (workspace + state now live
# inside the PZ install at <pz>/necroid/). Safe to keep ignored.
/data/workspace/
/data/.mod-config.json
/data/.mod-state-client.json
/data/.mod-state-server.json
/data/.update-cache-mods.json
/data/.import-tmp/
/data/.update-tmp/

# -----------------------------------------------------------------------------
# Build output (PyInstaller + wheels)
# -----------------------------------------------------------------------------
/dist/
/dist-archives/
/build/
/*.egg-info/

# -----------------------------------------------------------------------------
# Ephemeral assets generated at build time (macOS icns needs iconutil,
# so it's regenerated per build rather than committed).
# -----------------------------------------------------------------------------
/assets/necroid-icon.icns
/assets/necroid-icon.iconset/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
.pytest_cache/
.venv/

# -----------------------------------------------------------------------------
# Editor / OS junk
# -----------------------------------------------------------------------------
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
Thumbs.db
Desktop.ini
*.swp
*~
