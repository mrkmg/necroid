# -----------------------------------------------------------------------------
# Shared workspace populated by `necroid init` from one PZ install.
# Never commit — each user rebuilds from their own Steam install.
# -----------------------------------------------------------------------------
/data/workspace/

# -----------------------------------------------------------------------------
# Downloaded tooling. The tools/ dir itself is tracked via .gitkeep; contents are not.
# -----------------------------------------------------------------------------
/data/tools/*
!/data/tools/.gitkeep

# -----------------------------------------------------------------------------
# Local runtime state — user-specific, not shared
# -----------------------------------------------------------------------------
/data/.mod-config.json
/data/.mod-enter.json
/data/.mod-state-client.json
/data/.mod-state-server.json

# -----------------------------------------------------------------------------
# Build output (PyInstaller + wheels)
# -----------------------------------------------------------------------------
/dist/
/dist-archives/
/build/
/*.egg-info/

# -----------------------------------------------------------------------------
# Ephemeral assets generated at build time (macOS icns needs iconutil,
# so it's regenerated per build rather than committed).
# -----------------------------------------------------------------------------
/assets/necroid-icon.icns
/assets/necroid-icon.iconset/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
.pytest_cache/
.venv/

# -----------------------------------------------------------------------------
# Editor / OS junk
# -----------------------------------------------------------------------------
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
Thumbs.db
Desktop.ini
*.swp
*~
