# -----------------------------------------------------------------------------
# Per-profile PZ-sourced content (populated by `pz-java-modder init`).
# Never commit — each user rebuilds from their own Steam install.
# -----------------------------------------------------------------------------
/data/client/
/data/server/

# -----------------------------------------------------------------------------
# Downloaded tooling. The tools/ dir itself is tracked via .gitkeep; contents are not.
# -----------------------------------------------------------------------------
/data/tools/*
!/data/tools/.gitkeep

# -----------------------------------------------------------------------------
# Local runtime state — user-specific, not shared
# -----------------------------------------------------------------------------
/data/.mod-config.json

# -----------------------------------------------------------------------------
# Build output (PyInstaller + wheels)
# -----------------------------------------------------------------------------
/dist/
/pz-java-modder/build/
/pz-java-modder/dist/
/pz-java-modder/*.egg-info/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
.pytest_cache/
.venv/

# -----------------------------------------------------------------------------
# Editor / OS junk
# -----------------------------------------------------------------------------
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
Thumbs.db
Desktop.ini
*.swp
*~
