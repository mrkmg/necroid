package zombie.transparent_all;

import zombie.admin_xray.AdminXray;
import zombie.iso.IsoMovingObject;
import zombie.iso.IsoObject;

public final class TransparentAll {
    public static final float XRAY_ALPHA = 0.25F;

    private TransparentAll() {
    }

    public static boolean shouldFade(IsoObject obj) {
        return AdminXray.treeOverride && !(obj instanceof IsoMovingObject);
    }
}
